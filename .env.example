# ── LLM API Keys ───────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Models ─────────────────────────────────────────────
GROQ_MODEL_HEAVY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=qwen-qwq-32b
OLLAMA_MODEL=qwen2.5:7b-instruct
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Qdrant ─────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_MITRE=mitre_attack
QDRANT_COLLECTION_CVE=nvd_cve
QDRANT_COLLECTION_EXPLOITDB=exploitdb
QDRANT_COLLECTION_ATOMIC=atomic_red_team
QDRANT_COLLECTION_ICS=mitre_ics
QDRANT_COLLECTION_SIGMA=sigma_rules
QDRANT_COLLECTION_CISA=cisa_advisories

# ── Neo4j ──────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── NVD API (free key from nvd.nist.gov) ───────────────
NVD_API_KEY=your_nvd_api_key_here

# ── Campaign defaults ──────────────────────────────────
SAFE_MODE=true
STEALTH_LEVEL=high
MAX_THREADS=4
LOG_LEVEL=INFO
REPORTS_DIR=./reports
